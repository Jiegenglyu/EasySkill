{
  "schemaVersion": "0.1",
  "name": "api-replay-recorder",
  "packageName": "easyskill",
  "kind": "agent-skill",
  "description": "Fake and preserve human browser operations by recording UI actions, page transitions, downloads, and network requests, then generating reusable pre-skill materials.",
  "entrypoint": "api-replay-recorder/SKILL.md",
  "agentInstructions": "AGENTS.md",
  "requires": {
    "node": ">=18",
    "npm": true
  },
  "install": {
    "generic": "node install.mjs --target-dir <agent-skills-dir>",
    "codex": "node install.mjs --codex",
    "localContextOnly": "Read AGENTS.md and api-replay-recorder/SKILL.md directly from the cloned repository."
  },
  "commands": {
    "record": "npm run record -- <start-url> <run-dir>",
    "summarize": "npm run summarize -- <network.jsonl> <candidates.json> [user-actions.jsonl]",
    "replay": "npm run replay -- <operation.recipe.json> <inputs.json> [run-dir]"
  },
  "artifacts": [
    "storage-state.json",
    "session.json",
    "network.jsonl",
    "user-actions.jsonl",
    "candidates.json",
    "operation.recipe.json",
    "inputs.json",
    "validation.json",
    "results.jsonl",
    "downloads/",
    "screenshots/"
  ],
  "security": {
    "localSecretPatterns": [
      "cookies",
      "bearer tokens",
      "csrf tokens",
      "intranet URLs",
      "request bodies",
      "downloaded business data"
    ],
    "doNotCommit": [
      "runs/",
      "storage-state.json",
      "network.jsonl",
      "user-actions.jsonl",
      "downloads/"
    ]
  }
}
